# HazelJS AI Resume Screener Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/resume_screener"

# AI Providers
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG=your_openai_org_id_here
ANTHROPIC_API_KEY=your_claude_api_key_here

# Default AI Provider (openai, anthropic, gemini, cohere)
DEFAULT_AI_PROVIDER=anthropic

# Vector Store (Pinecone for production)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=resume-vectors

# Cache (Redis for production)
REDIS_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
