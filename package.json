{
  "name": "ai-resume-screener",
  "version": "1.0.0",
  "description": "AI-Powered Resume Screener built with HazelJS - Upload PDFs, embed candidates, and get AI-ranked matches",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "simple": "ts-node src/app.simple.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:reset": "npx prisma migrate reset"
  },
  "keywords": [
    "ai",
    "resume",
    "screener",
    "hazeljs",
    "rag",
    "embedding",
    "matching"
  ],
  "author": "HazelJS Blog",
  "license": "Apache-2.0",
  "dependencies": {
    "@hazeljs/agent": "^0.3.0",
    "@hazeljs/ai": "^0.3.0",
    "@hazeljs/cache": "^0.3.0",
    "@hazeljs/core": "^0.3.0",
    "@hazeljs/memory": "^0.3.0",
    "@hazeljs/prisma": "^0.3.0",
    "@hazeljs/rag": "^0.3.0",
    "@hazeljs/swagger": "^0.3.0",
    "@hazeljs/websocket": "^0.3.0",
    "@prisma/client": "^5.6.0",
    "@types/cors": "^2.8.19",
    "@types/pdf-parse": "^1.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.6",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.6",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.8.0",
    "@types/uuid": "^9.0.5",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
